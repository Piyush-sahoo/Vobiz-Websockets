# ─────────────────────────────────────────────────────────────────────────────
# server/.env.example  —  VOBIZ INTERNAL
# ─────────────────────────────────────────────────────────────────────────────
# This server is hosted and managed by Vobiz.
# Customers do NOT need this. They use the agent/ folder.
#
# What this server does:
#   - Runs the Stream Application Builder API
#   - Generates Vobiz XML from customer config (stream URL + toggles)
#   - Uploads XML to S3 so Vobiz can fetch it on every call
#   - Serves the builder UI (index.html) hosted on S3
# ─────────────────────────────────────────────────────────────────────────────

# Port for this server
# Avoid 5000 on Mac — AirPlay/Control Center uses it
HTTP_PORT=8000

# ─── ngrok (only needed for local dev/testing) ────────────────────────────────
# In production this server runs on a real domain — no ngrok needed.
# For local testing only: add your ngrok token to get a public URL.
NGROK_AUTH_TOKEN=

# ─── Local mode URL ───────────────────────────────────────────────────────────
# Used to build answer_urls when S3 is not configured (local dev only).
# In local mode set to:  http://localhost:8000
# With ngrok set to:     https://your-ngrok-url.ngrok.io  (after first run)
# In production set to:  https://your-vobiz-domain.com
LOCAL_BASE_URL=http://localhost:8000

# ─── AWS S3 ───────────────────────────────────────────────────────────────────
# Required for production.
# The generated XMLs are uploaded here as: s3://BUCKET/vobiz-xml/{app_id}.xml
# The frontend (index.html) is uploaded here as: s3://BUCKET/index.html
# Leave blank to run in local mode (XML served from this server instead).
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
S3_BUCKET_NAME=
