# ─────────────────────────────────────────────────────────────────────────────
# agent/.env.example  —  CUSTOMER COPY
# ─────────────────────────────────────────────────────────────────────────────
# This is the file YOUR CUSTOMER fills in and runs on their own machine.
# Vobiz does NOT see these keys. Everything here belongs to the customer.
#
# What this agent does:
#   - Runs a full AI voice agent on the customer's machine
#   - Receives live call audio from Vobiz via WebSocket
#   - Transcribes speech using Deepgram (customer's key)
#   - Generates responses using OpenAI GPT (customer's key)
#   - Speaks back using OpenAI TTS (customer's key)
#   - Exposes a public URL via ngrok for Vobiz to connect to
# ─────────────────────────────────────────────────────────────────────────────

# ─── Server ports ─────────────────────────────────────────────────────────────
# HTTP_PORT: the FastAPI server that handles Vobiz webhooks
# Avoid 5000 on Mac — AirPlay uses it
HTTP_PORT=8001

# AGENT_WS_PORT: the internal WebSocket server agent.py listens on
# This port is local-only — never exposed to the internet directly
AGENT_WS_PORT=5001

# ─── ngrok — REQUIRED ─────────────────────────────────────────────────────────
# ngrok creates a public URL so Vobiz can reach your local machine.
# Get your token at: https://dashboard.ngrok.com/authtokens
NGROK_AUTH_TOKEN=your_ngrok_auth_token

# ─── OpenAI — REQUIRED ────────────────────────────────────────────────────────
# Used for:
#   - GPT-4o-mini: generates the AI's spoken responses
#   - TTS-1: converts text responses to voice audio
# These are YOUR keys. Vobiz never sees them.
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key

# TTS voice for the AI agent
# Options: alloy | echo | fable | onyx | nova | shimmer
OPENAI_TTS_VOICE=alloy

# ─── Deepgram — REQUIRED ──────────────────────────────────────────────────────
# Used for live speech-to-text transcription of the caller's voice.
# These are YOUR keys. Vobiz never sees them.
# Get yours at: https://console.deepgram.com
DEEPGRAM_API_KEY=your_deepgram_api_key

# ─── AI Agent Personality ─────────────────────────────────────────────────────
# This is the system prompt that defines how your AI agent behaves.
# Customize this for your use case.
AGENT_SYSTEM_PROMPT=You are a helpful AI phone assistant. Be concise and conversational. Keep responses under 2 sentences.

# ─── Vobiz Credentials — needed for make_call.py (outbound calls) ─────────────
# Your Vobiz account credentials for triggering outbound calls.
# Get these from your Vobiz dashboard.
VOBIZ_AUTH_ID=your_vobiz_auth_id
VOBIZ_AUTH_TOKEN=your_vobiz_auth_token

# ─── Call numbers — needed for make_call.py ───────────────────────────────────
FROM_NUMBER=+91XXXXXXXXXX
TO_NUMBER=+91XXXXXXXXXX
